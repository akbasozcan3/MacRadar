# ==============================================================================
# MacRadar Backend Configuration
# ==============================================================================
# Copy this file to .env and update the values for your environment.
# DO NOT commit .env files with real credentials to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------------------------
PORT=8090
APP_BASE_URL=http://127.0.0.1:8090

# Environment: development, testing, production
# Production mode enforces stricter security validations
APP_ENV=development

# ------------------------------------------------------------------------------
# Database Configuration
# ------------------------------------------------------------------------------
DATABASE_URL=postgres://macradar:macradar@localhost:5432/macradar?sslmode=disable

# Connection pool settings
DB_MAX_CONNS=12
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=15m

# ------------------------------------------------------------------------------
# Redis Cache Configuration (Optional but recommended for fast feeds/messages)
# ------------------------------------------------------------------------------
# Example: redis://localhost:6379/0
REDIS_URL=
REDIS_CACHE_NAMESPACE=macradar

# ------------------------------------------------------------------------------
# Mapbox (server-side geocoding for post location search — worldwide)
# ------------------------------------------------------------------------------
# Same public token as the mobile app; used only for GET /api/v1/explore/search/places
MAPBOX_PUBLIC_TOKEN=

# ------------------------------------------------------------------------------
# Security Configuration
# ------------------------------------------------------------------------------
# IMPORTANT: Change this to a strong random string (32+ chars) in production!
JWT_SECRET=change-me-to-a-secure-random-string-in-production
# Firebase/Google OAuth web client ID used to validate incoming googleIdToken.
GOOGLE_WEB_CLIENT_ID=112430380576-1s4htkhf9j58fcqheva1vprshcstnr0u.apps.googleusercontent.com

# Optional admin token for hard-deleting posts via:
# DELETE /api/v1/admin/profile/posts/{postID}
# This endpoint still requires a valid Bearer session and this header:
# X-MacRadar-Admin-Token: <value>
ADMIN_POST_HARD_DELETE_TOKEN=

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://10.0.2.2:8081

# Bcrypt password hashing cost (8-14, higher = more secure but slower)
BCRYPT_COST=10

# ------------------------------------------------------------------------------
# Email (SMTP) Configuration
# ------------------------------------------------------------------------------
# Gmail SMTP example. Use an App Password, not your normal account password.
# Spaced app passwords are accepted; the Go config normalizes them automatically.
# To generate a Gmail App Password:
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Create a new app password for "Mail"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-account@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=MacRadar Security <your-account@gmail.com>
# Optional SMTP flags
# SMTP_SECURE=true   # usually true for 465, false for 587
# SMTP_REQUIRE_TLS=true
# SMTP_TIMEOUT_MS=12000

# Enable debug preview mode (shows verification codes in API response)
# Set to false in production!
AUTH_DEBUG_PREVIEW=false

# ------------------------------------------------------------------------------
# Email Verification Configuration
# ------------------------------------------------------------------------------
VERIFICATION_TOKEN_TTL=24h
VERIFICATION_RESEND_COOLDOWN=60s
VERIFICATION_SEND_WINDOW=1h
VERIFICATION_MAX_SENDS_PER_WINDOW=5

# ------------------------------------------------------------------------------
# Password Reset Configuration
# ------------------------------------------------------------------------------
PASSWORD_RESET_CODE_TTL=10m
PASSWORD_RESET_MAX_ATTEMPTS=5
PASSWORD_RESET_RESEND_COOLDOWN=60s
PASSWORD_RESET_SEND_WINDOW=1h
PASSWORD_RESET_MAX_SENDS_PER_WINDOW=5

# ------------------------------------------------------------------------------
# Rate Limiting Configuration
# ------------------------------------------------------------------------------
LOGIN_MAX_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW=15m
SEARCH_RATE_LIMIT_MAX_REQUESTS=90
SEARCH_RATE_LIMIT_WINDOW=1m

# Popular search suggestion score model A/B traffic split.
# model A: baseline decay/weights
# model B: stronger hourly decay + segment-aware weighting
SEARCH_POPULAR_AB_ENABLED=true
SEARCH_POPULAR_B_TRAFFIC_PERCENT=50

# ------------------------------------------------------------------------------
# HTTP Server Configuration
# ------------------------------------------------------------------------------
READ_HEADER_TIMEOUT=3s
IDLE_TIMEOUT=60s
SHUTDOWN_TIMEOUT=10s
# Voice upload payloadlarini da kapsayacak varsayilan limit (12 MB)
MAX_REQUEST_BODY_BYTES=12582912

# ------------------------------------------------------------------------------
# Rust Sensor Bridge Configuration (Optional)
# ------------------------------------------------------------------------------
# The Go backend can optionally connect to a Rust sensor websocket hub
RUST_SENSOR_BRIDGE_ENABLED=false
RUST_SENSOR_WS_URL=ws://127.0.0.1:8181/ws/sensors
RUST_SENSOR_BRIDGE_HANDSHAKE_TIMEOUT=5s
RUST_SENSOR_BRIDGE_RECONNECT_DELAY=2s

# Rust sensor service local bind
RUST_SENSOR_HOST=127.0.0.1
RUST_SENSOR_PORT=8181
GO_TRACKING_INGEST_URL=http://127.0.0.1:8090/api/v1/tracking/ingest
GO_TRACKING_INGEST_TOKEN=macradar-tracking-ingest-dev
TRACKING_INGEST_TOKEN=macradar-tracking-ingest-dev
TRACKING_SESSION_INACTIVITY_TIMEOUT=10m

# ------------------------------------------------------------------------------
# Development Tools (Non-production only)
# ------------------------------------------------------------------------------
# Token required to reset auth data in development
DEV_RESET_TOKEN=macradar-local-reset

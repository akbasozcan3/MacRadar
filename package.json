{
  "name": "MacRadar",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "backend:clean": "node backend/scripts/clean-backend-stack.js",
    "backend:fresh": "npm run backend:clean && npm run backend:dev",
    "android": "npm run env:generate && react-native run-android --active-arch-only",
    "backend:db:down": "node -e \"console.log('Docker dev db disabled. Node-only backend mode is active.')\"",
    "backend:db:up": "node -e \"console.log('Docker dev db disabled. Node-only backend mode is active.')\"",
    "backend:auth:reset": "node backend/scripts/reset-dev-auth.js",
    "backend:users:wipe": "node backend/scripts/reset-dev-auth.js",
    "backend:dev": "node backend/scripts/start-node-stack.js",
    "backend:go": "node backend/scripts/start-go.js",
    "backend:start": "node backend/scripts/start-node-server.js",
    "backend:test": "node backend/scripts/test-go-auth-flow.js",
    "backend:test:profile": "node backend/scripts/test-go-profile-settings.js",
    "backend:test:node": "node backend/scripts/test-node-backend.js",
    "backend:test:go": "node backend/scripts/test-go-backend.js",
    "backend:test:go:matrix": "node backend/scripts/test-go-flow-matrix.js",
    "backend:test:go:unit": "node backend/scripts/test-go-unit.js",
    "backend:test:tabs": "node backend/scripts/test-tab-backend-contracts.js",
    "backend:test:all": "node backend/scripts/run-backend-test-suite.js",
    "env:generate": "node scripts/generate-app-env.js",
    "i18n:sync": "node scripts/extract-en-translations.mjs",
    "ios": "npm run env:generate && react-native run-ios",
    "lint": "eslint .",
    "postinstall": "npm run env:generate && node scripts/patch-css-interop.js",
    "start": "npm run env:generate && node backend/scripts/start-node-app-stack.js",
    "start:fresh": "npm run backend:clean && npm run start",
    "start:metro": "npm run env:generate && node scripts/patch-css-interop.js && react-native start",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run lint && npm test -- --runInBand && npm run backend:test:all"
  },
  "dependencies": {
    "@notifee/react-native": "^9.1.8",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/blur": "^4.4.1",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-native/new-app-screen": "0.84.1",
    "@rnmapbox/maps": "^10.2.10",
    "@shopify/flash-list": "^2.3.0",
    "nativewind": "^4.2.2",
    "react": "19.2.3",
    "react-native": "0.84.1",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-reanimated": "4.2.2",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-step-indicator": "^1.0.3",
    "react-native-svg": "^15.15.4",
    "react-native-vector-icons": "^10.3.0",
    "react-native-video": "^6.19.0",
    "react-native-vision-camera": "^4.7.3",
    "react-native-worklets": "^0.7.4"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}

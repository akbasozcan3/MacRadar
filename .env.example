# ==============================================================================
# MacRadar Mobile App Environment Configuration
# ==============================================================================
# Copy this file to .env and update the values for your environment.
# The generate-app-env.js script uses these values to create appEnv.generated.ts
# ==============================================================================

# ------------------------------------------------------------------------------
# API Configuration
# ------------------------------------------------------------------------------
# Backend API base URL for the mobile app.
# If omitted, the app automatically falls back to platform-local dev host:
#   - Android emulator -> http://10.0.2.2:8090
#   - iOS simulator    -> http://127.0.0.1:8090
#   - Physical device  -> Your computer's local IP (e.g., http://192.168.1.100:8090)
MACRADAR_API_BASE_URL=

# Optional API port used only for local fallback URL construction.
# Change this if your backend runs on a different port.
MACRADAR_API_PORT=8090

# ------------------------------------------------------------------------------
# WebSocket Configuration
# ------------------------------------------------------------------------------
# Optional explicit WS base URL (ws:// or wss://).
# If omitted, it is automatically derived from MACRADAR_API_BASE_URL.
# Use wss:// for production environments with HTTPS.
MACRADAR_WS_BASE_URL=

# Optional dedicated sensor websocket endpoint.
# Production example: wss://macradar-rust-sensor.onrender.com/ws/sensors
MACRADAR_SENSOR_WS_URL=

# ------------------------------------------------------------------------------
# Mapbox Configuration
# ------------------------------------------------------------------------------
# Public Mapbox token (pk...) used by mobile location autocomplete.
MACRADAR_MAPBOX_PUBLIC_TOKEN=

# ==============================================================================
# Development Notes
# ==============================================================================
# To connect from a physical device to your local backend:
# 1. Find your computer's local IP (ipconfig on Windows, ifconfig on Mac/Linux)
# 2. Set MACRADAR_API_BASE_URL=http://YOUR_LOCAL_IP:8090
# 3. Ensure your firewall allows connections on port 8090
# 4. Run npm run env:generate to regenerate the config
# ==============================================================================
